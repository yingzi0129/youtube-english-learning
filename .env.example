# Supabase 配置（使用 Supabase Auth + RLS 策略）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 绝对不能暴露
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI 配置（OpenAI 兼容中转站）
AI_API_BASE_URL=
AI_API_KEY=
# 默认模型（可在标注页覆盖）
AI_MODEL=gpt-5.2

# 试用账号配置
TRIAL_PHONE=
TRIAL_PASSWORD=
# 可选：如需用用户ID识别试用账号
TRIAL_USER_ID=

# 腾讯云 COS 配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-guangzhou
COS_BUCKET=your_cos_bucket
COS_ENDPOINT=
NEXT_PUBLIC_COS_DOMAIN=https://video.speak-video.cn

# 补齐 COS 的超时时间配置
COS_BACKFILL_FETCH_TIMEOUT_MS=360000
COS_BACKFILL_UPLOAD_TIMEOUT_MS=360000
